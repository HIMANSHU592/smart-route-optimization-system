import tkinter as tk
from tkinter import messagebox
import heapq
import folium
import webbrowser
import random

cities = {
    "CHANDIGARH": (30.7333, 76.7794),
    "DELHI": (28.7041, 77.1025),
    "AMBALA": (30.3752, 76.7821),
    "LUDHIANA": (30.9010, 75.8573),
    "AMRITSAR": (31.6340, 74.8723)
}

graph_base = {
    "CHANDIGARH": {
        "AMBALA": (50, 3),
        "LUDHIANA": (100, 2),
        "DELHI": (260, 1)
    },

    "AMBALA": {
        "CHANDIGARH": (50, 3),
        "DELHI": (200, 3),
        "LUDHIANA": (120, 2)
    },

    "DELHI": {
        "AMBALA": (200, 3),
        "LUDHIANA": (250, 2),
        "CHANDIGARH": (260, 1)
    },

    "LUDHIANA": {
        "CHANDIGARH": (100, 2),
        "AMBALA": (120, 2),
        "DELHI": (250, 2),
        "AMRITSAR": (140, 3)
    },

    "AMRITSAR": {
        "LUDHIANA": (140, 3),
        "DELHI": (450, 1)
    }
}

def generate_graph():
    graph = {}
    for node in graph_base:
        graph[node] = {}
        for neighbor in graph_base[node]:
            distance, priority = graph_base[node][neighbor]
            traffic = random.randint(1, 5)  # dynamic traffic
            graph[node][neighbor] = (distance, traffic, priority)
    return graph


def normal_route(graph, start, end):
    visited = set()
    queue = [(start, [start])]

    while queue:
        node, path = queue.pop(0)

        if node == end:
            return path

        visited.add(node)

        for neighbor in graph[node]:
            if neighbor not in visited:
                queue.append((neighbor, path + [neighbor]))

    return []


def dijkstra_shortest(graph, start, end):
    queue = [(0, start, [])]
    visited = set()

    while queue:
        cost, node, path = heapq.heappop(queue)

        if node in visited:
            continue

        visited.add(node)
        path = path + [node]

        if node == end:
            return path

        for neighbor in graph[node]:
            distance, _, _ = graph[node][neighbor]
            heapq.heappush(queue, (cost + distance, neighbor, path))

    return []

def dijkstra_emergency(graph, start, end):
    queue = [(0, start, [])]
    visited = set()

    while queue:
        cost, node, path = heapq.heappop(queue)

        if node in visited:
            continue

        visited.add(node)
        path = path + [node]

        if node == end:
            return path

        for neighbor in graph[node]:
            distance, traffic, priority = graph[node][neighbor]
            new_cost = cost + distance + (traffic * 30) - (priority * 20)
            heapq.heappush(queue, (new_cost, neighbor, path))

    return []

def calculate_distance(graph, path):
    total = 0
    for i in range(len(path) - 1):
        curr = path[i]
        nxt = path[i + 1]
        if nxt in graph[curr]:
            total += graph[curr][nxt][0]
    return total

def show_map(graph, normal_path, shortest_path, emergency_path):

    m = folium.Map(location=cities[normal_path[0]], zoom_start=6)

   
    for city in cities:
        folium.Marker(location=cities[city], popup=city).add_to(m)

  
    normal_dist = calculate_distance(graph, normal_path)
    shortest_dist = calculate_distance(graph, shortest_path)
    emergency_dist = calculate_distance(graph, emergency_path)


    folium.PolyLine(
        [cities[c] for c in normal_path],
        color="gray",
        weight=3,
        tooltip=f"Normal: {normal_dist} km"
    ).add_to(m)

    folium.PolyLine(
        [cities[c] for c in shortest_path],
        color="blue",
        weight=4,
        tooltip=f"Shortest: {shortest_dist} km"
    ).add_to(m)

    folium.PolyLine(
        [cities[c] for c in emergency_path],
        color="red",
        weight=5,
        tooltip=f"Emergency: {emergency_dist} km"
    ).add_to(m)

   
    mid = shortest_path[len(shortest_path)//2]
    folium.Marker(
        location=cities[mid],
        popup=f"Shortest Distance: {shortest_dist} km"
    ).add_to(m)

    m.save("final_route.html")
    webbrowser.open("final_route.html")

def find_routes():
    start = source_var.get()
    end = dest_var.get()

    if start == end:
        messagebox.showerror("Error", "Same city selected!")
        return

    graph = generate_graph()

    normal_path = normal_route(graph, start, end)
    shortest_path = dijkstra_shortest(graph, start, end)
    emergency_path = dijkstra_emergency(graph, start, end)

    if not normal_path or not shortest_path or not emergency_path:
        result_label.config(text="No valid route found!")
        return

    normal_distance = calculate_distance(graph, normal_path)
    shortest_distance = calculate_distance(graph, shortest_path)
    emergency_distance = calculate_distance(graph, emergency_path)

    improvement = normal_distance - shortest_distance

    result_label.config(
        text=f"🚗 Normal Route:\n{' → '.join(normal_path)}\nDistance: {normal_distance} km\n\n"
             f"📍 Shortest Route:\n{' → '.join(shortest_path)}\nDistance: {shortest_distance} km\n\n"
             f"🚑 Emergency Route:\n{' → '.join(emergency_path)}\nDistance: {emergency_distance} km\n\n"
             f"✅ Improvement: {improvement} km shorter"
    )

    show_map(graph, normal_path, shortest_path, emergency_path)


root = tk.Tk()
root.title(" Smart Route Optimization System")
root.geometry("520x450")

tk.Label(root, text="Smart Route Optimization System",
         font=("Arial", 16, "bold")).pack(pady=10)

source_var = tk.StringVar(root)
dest_var = tk.StringVar(root)

source_var.set("CHANDIGARH")
dest_var.set("DELHI")

tk.Label(root, text="Select Source").pack()
tk.OptionMenu(root, source_var, *cities.keys()).pack()

tk.Label(root, text="Select Destination").pack()
tk.OptionMenu(root, dest_var, *cities.keys()).pack()

tk.Button(root, text="Find Routes",
          command=find_routes, bg="green", fg="white").pack(pady=15)

result_label = tk.Label(root, text="", font=("Arial", 11), justify="left")
result_label.pack(pady=20)

root.mainloop()
